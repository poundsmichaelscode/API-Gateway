{
  "name": "high-performance-api-gateway",
  "version": "1.0.0",
  "description": "Production-grade API Gateway Service built with Node.js, TypeScript, Redis, PostgreSQL, Nginx, Prometheus and Grafana.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "load:test": "k6 run k6/gateway-smoke.js",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "keywords": ["api-gateway", "typescript", "redis", "prometheus", "nginx", "postgresql", "microservices"],
  "author": "Olayenikan Michael",
  "license": "MIT",
  "dependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/express-rate-limit": "latest",
    "@types/helmet": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/uuid": "latest",
    "bcryptjs": "latest",
    "compression": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-mongo-sanitize": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "http-proxy-middleware": "latest",
    "ioredis": "latest",
    "jsonwebtoken": "latest",
    "lru-cache": "latest",
    "node-cron": "latest",
    "opossum": "latest",
    "pg": "latest",
    "pino": "latest",
    "pino-http": "latest",
    "prom-client": "latest",
    "uuid": "latest",
    "ws": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/bcryptjs": "latest",
    "@types/jest": "latest",
    "@types/supertest": "latest",
    "@types/ws": "latest",
    "eslint": "latest",
    "jest": "latest",
    "supertest": "latest",
    "ts-jest": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
